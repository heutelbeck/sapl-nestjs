{
  "name": "@sapl/nestjs",
  "version": "2.0.0",
  "description": "SAPL authorization for NestJS - ABAC with constraint handling",
  "author": "Dominic Heutelbeck",
  "keywords": [
    "sapl",
    "nestjs",
    "abac",
    "authorization",
    "policy",
    "access-control",
    "streaming"
  ],
  "homepage": "https://github.com/heutelbeck/sapl-nestjs#readme",
  "bugs": {
    "url": "https://github.com/heutelbeck/sapl-nestjs/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./mongoose": {
      "types": "./dist/mongoose/index.d.ts",
      "default": "./dist/mongoose/index.js"
    },
    "./prisma": {
      "types": "./dist/prisma/index.d.ts",
      "default": "./dist/prisma/index.js"
    }
  },
  "files": [
    "dist",
    "dist/transport/codec/*.proto",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npm run build:copy-protos",
    "build:copy-protos": "node -e \"const fs=require('fs');const src='lib/transport/codec';const dst='dist/transport/codec';fs.mkdirSync(dst,{recursive:true});for(const f of fs.readdirSync(src).filter(f=>f.endsWith('.proto'))){fs.copyFileSync(src+'/'+f,dst+'/'+f);}\"",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:it": "jest --config jest.it.config.ts",
    "lint": "eslint lib test",
    "format": "prettier --write \"lib/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "prettier --check \"lib/**/*.ts\" \"test/**/*.ts\"",
    "knip": "knip",
    "prepublishOnly": "npm run build",
    "pack:install-demo": "npm run build && npm pack && npm --prefix ../sapl-nestjs-demo install $(pwd)/sapl-nestjs-$npm_package_version.tgz"
  },
  "peerDependencies": {
    "@nestjs-cls/transactional": ">=2.0.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@prisma/client": ">=6.0.0",
    "@toss/nestjs-aop": "^2.1.0",
    "mongoose": ">=7.0.0",
    "nestjs-cls": "^6.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "@nestjs-cls/transactional": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@toss/nestjs-aop": "^2.1.7",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.0.0",
    "knip": "^6.14.2",
    "mongoose": "^9.6.3",
    "nestjs-cls": "^6.2.0",
    "pg": "^8.21.0",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "testcontainers": "^12.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.59.4"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/heutelbeck/sapl-nestjs"
  },
  "overrides": {
    "glob": "^13.0.0"
  },
  "dependencies": {
    "@rsocket/composite-metadata": "1.0.0-alpha.3",
    "@rsocket/core": "1.0.0-alpha.3",
    "@rsocket/tcp-client": "1.0.0-alpha.3",
    "openid-client": "^6.8.4",
    "protobufjs": "^8.4.2",
    "safe-regex2": "^5.0.0",
    "undici": "^8.3.0"
  }
}
